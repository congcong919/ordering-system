rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Menu: anyone can read, only admins can write
    match /menus/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Orders: customer can read/create their own; admin can read/update all
    match /orders/{id} {
      allow read: if request.auth != null
        && (resource.data.customerId == request.auth.uid
            || request.auth.token.role == 'admin');

      allow create: if request.auth != null
        && request.resource.data.customerId == request.auth.uid;

      allow update: if request.auth != null
        && request.auth.token.role == 'admin';
    }

    // Users: each user reads/writes their own doc; admins can read all
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Notifications: each user reads/writes their own
    match /notifications/{id} {
      allow read, write: if request.auth != null
        && resource.data.recipientId == request.auth.uid;

      allow create: if request.auth != null; // server creates via Admin SDK
    }

    // Reservations: admin reads/updates all; owner reads if customerId is set;
    // server creates via Admin SDK (unrestricted)
    match /reservations/{id} {
      allow read: if request.auth != null
        && (request.auth.token.role == 'admin'
            || (resource.data.customerId != null
                && resource.data.customerId == request.auth.uid));

      allow update: if request.auth != null
        && request.auth.token.role == 'admin';
    }

    // Config: public read (opening hours, table list); admin-only write
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
